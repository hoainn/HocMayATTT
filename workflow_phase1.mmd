flowchart TD
    IDS18["📂 CIC-IDS 2018\n02-16-2018.csv\n02-21-2018.csv\nsample 100,000 rows / file"]

    subgraph PH1["PHASE 1 — FAMS Feature Selection  (CIC-IDS 2018)"]
        direction TB

        L1["① Load & Harmonise\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n• Read CSV with low_memory=False\n• Strip whitespace from column names\n• Rename 48 abbreviated → canonical\n  e.g.  Dst Port → Destination Port\n         Flow Byts/s → Flow Bytes/s\n         Init Fwd Win Byts → Init Fwd Win Bytes\n• Drop duplicate-header rows  Label == Label\n• Drop Timestamp  absent in DDoS2019\n• Drop Destination Port  absent in DDoS2019"]

        PP1["② Preprocess\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n• Coerce object cols → pd.to_numeric errors=coerce\n• Replace +∞ / −∞ → NaN\n• dropna → remove incomplete rows\n• drop_duplicates\n→ 77 numeric feature candidates remain"]

        ENC["③ Binary Label Encoding\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nBENIGN → 0       any attack → 1"]

        SPL["④ Stratified Train/Test Split  70% / 30%\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nStratified by label to preserve class ratio\nrandom_state = 42"]

        SCL["⑤ MinMaxScaler  fit on Train only\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nfit_transform on X_train\ntransform on X_test\nPrevents data leakage from test set"]

        SMO["⑥ SMOTE  train set only\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nApply if  max_class / min_class > 2\nSynthetic Minority Over-sampling\nBalances class distribution before feature scoring"]

        subgraph FS["⑦ Five Feature Selection Methods  —  top-25 features each"]
            direction LR
            M1["🔹 Method 1\nVariance Filter\n─────────────\nRemove zero-variance\nfeatures first\nRank remainder by σ²\nTop-25 selected"]
            M2["🔹 Method 2\nMutual Information\n─────────────\nMeasure dependency\nbetween each feature\nand binary label\nTop-25 by MI score"]
            M3["🔹 Method 3\nRFE Backward Elim.\n─────────────\nDecisionTree depth=5\nsubsample 50k rows\nstep=3 features/round\nTop-25 selected"]
            M4["🔹 Method 4\nLasso L1\n─────────────\nLogisticRegression\npenalty=l1  C=0.1\nsubsample 80k rows\nRank by |coef|"]
            M5["🔹 Method 5\nRF Importance\n─────────────\n50 trees depth=10\nmax_samples=0.8\nsubsample 80k rows\nGini importance"]
        end

        VOTE["⑧ FAMS Vote Aggregation\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nCount how many methods selected each feature  max = 5\nRetain features where  votes > 3   i.e. ≥ 4 of 5 methods agree\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n✅  8 FINAL FEATURES SELECTED\n Bwd Packet Length Std   ·   Fwd Packet Length Std\n Fwd Packet Length Max   ·   Subflow Fwd Bytes\n Fwd Header Length       ·   Init Fwd Win Bytes\n Subflow Fwd Packets     ·   Fwd Packet Length Mean"]
    end

